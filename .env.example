# Your VBOUT API User Key (keep secret)
VBOUT_API_KEY=

# Firecrawl (keep secret)
FIRECRAWL_API_KEY=

# Public base URL used for uploaded media links (must be internet-reachable for VBOUT/LinkedIn)
# Example (local testing with tunnel): https://your-subdomain.ngrok-free.app
PUBLIC_BASE_URL=

# Vercel Blob token (required on Vercel for reliable media uploads)
BLOB_READ_WRITE_TOKEN=

# Automation / Cron (Vercel)
CRON_SECRET=
AUTOMATION_CHANNEL=linkedin
AUTOMATION_CHANNEL_ID=
AUTOMATION_LOOKBACK_DAYS=2
AUTOMATION_MODEL=spark-1-mini

# Server
PORT=3000
